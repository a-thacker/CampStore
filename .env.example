# ---- Front-end (exposed to browser — must be VITE_ prefixed; these are PUBLIC) ----
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key
VITE_SQUARE_APP_ID=sandbox-sq0idb-XXXXXXXXXXXXXXXX
VITE_SQUARE_LOCATION_ID=LXXXXXXXXXXXXX
# 'sandbox' loads Square's sandbox SDK + test cards; 'production' goes live
VITE_SQUARE_ENVIRONMENT=sandbox

# ---- Server-only (Netlify Functions) — SECRET, never VITE_ prefixed ----
SQUARE_ACCESS_TOKEN=EAAAEXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SQUARE_LOCATION_ID=LXXXXXXXXXXXXX
SQUARE_ENVIRONMENT=sandbox

# Service-role key — lets the payment/refund functions verify the caller's
# login and recompute prices/refund amounts server-side. SECRET. Never VITE_.
# (Supabase → Project Settings → API → service_role key)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Lock the payment/refund endpoints to your live site origin(s). Comma-sep.
# Leave blank only for local dev.
ALLOWED_ORIGINS=https://YOUR-SITE.netlify.app

# Set to 'true' to allow refunds only for users with app_metadata.role='admin'.
REFUND_ADMIN_ONLY=false
